# 로컬 전용 외부 API 인증키 예시. 실제 값은 git에 추적되지 않는 env.local.properties에 입력한다.
MY_SQL_END_POINT=localhost
MY_SQL_PORT=3306
MY_SQL_DB_NAME=nolate
MY_SQL_DB_USERNAME=nolate_user
MY_SQL_DB_PASSWORD=

JWT_SECRET_KEY=
JWT_ISSUER=nolate

GROQ_ENABLED=false
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b

FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=nolate-cbdf2
FIREBASE_CREDENTIALS_PATH=/config/firebase.json

SEOUL_OPENAPI_KEY=
SEOUL_SUBWAY_API_KEY=
SEOUL_BUS_API_KEY=
TAGO_API_KEY=
TAGO_BUS_API_KEY=
TMAP_ENABLED=false
TMAP_APP_KEY=

# SNS provider proof 검증용 공개 애플리케이션 식별자(비밀키가 아님)
SNS_KAKAO_APP_ID=
# Apple bundle/service client id를 comma-separated로 입력
SNS_APPLE_AUDIENCES=
